# OneQueue Environment Configuration
# Copy to .env and fill in your values. DO NOT commit .env with real secrets.

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
# Optional: GPU node URL (e.g. Tailscale/LAN address)
OLLAMA_GPU_URL=http://100.95.92.117:9001

# Database
DATABASE_URL=sqlite:///./data/onequeue.db

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Worker polling interval (seconds)
POLLING_INTERVAL_SECONDS=1.0

# NVIDIA API Keys (comma-separated for multi-key round-robin rotation)
# Get keys from https://build.nvidia.com/
# Example:
# NVIDIA_API_KEYS=nvapi-key1-abc123,nvapi-key2-def456
#
# For backward compatibility, a single key still works:
# NVIDIA_API_KEY=nvapi-single-key-here
NVIDIA_API_KEYS=

# Prefer local Ollama GPU for low-cost background jobs (true/false)
PREFER_LOCAL_GPU=true
