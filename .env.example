OLLAMA_HOST=http://127.0.0.1:11434
QUEUE_WORKER_CONCURRENCY=2
THRESHOLD_CPU=80
THRESHOLD_RAM=80
THRESHOLD_DISK=80
TASK_TIMEOUT=60
MAX_ATTEMPTS=3

# NVIDIA API Keys (supports rotation for rate limit handling)
# Primary key
NVIDIA_API_KEY=nvapi-YOUR_PRIMARY_KEY
# Additional keys for rotation (optional)
NVIDIA_API_KEY_1=nvapi-YOUR_SECOND_KEY
NVIDIA_API_KEY_2=nvapi-YOUR_THIRD_KEY
# Add more as needed: NVIDIA_API_KEY_3, NVIDIA_API_KEY_4, etc.

# KILO Gateway API Key (for KILO model routing)
KILO_API_KEY=your-kilo-api-key